version: v1alpha1
debug: false
persist: true
machine:
  type: controlplane
  token: {{ ENV.MACHINE_TOKEN }}
  ca:
    crt: {{ ENV.MACHINE_CA_CRT }}
    {% if ENV.IS_CONTROLLER %}
    key: {{ ENV.MACHINE_CA_KEY }}
    {% endif %}
  certSANs:
    - cluster.local
    - servonet.lan
    - 127.0.0.1
  kubelet:
    defaultRuntimeSeccompProfileEnabled: true
    disableManifestsDirectory: true
    extraArgs:
      image-gc-high-threshold: 70
      image-gc-low-threshold: 65
    extraConfig:
      maxParallelImagePulls: 10
      maxPods: 200
      serializeImagePulls: false
    nodeIP:
      validSubnets:
          - 10.4.0.0/16
    image: ghcr.io/siderolabs/kubelet:v1.35.2
  network: {}
  install:
    disk: /dev/sda
    image: factory.talos.dev/metal-installer/ee21ef4a5ef808a9b7484cc0dda0f25075021691c8c09a276591eedb638ea1f9:v1.12.5
    wipe: false
    grubUseUKICmdline: true
  features:
    apidCheckExtKeyUsage: true
    diskQuotaSupport: true
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: true # Requires Cilium socketLB features
      resolveMemberNames: true
    kubePrism:
      enabled: true
      port: 7445
    {% if ENV.IS_CONTROLLER %}
    kubernetesTalosAPIAccess:
      enabled: true
      allowedKubernetesNamespaces:
        - actions-runner-system
        - system-upgrade
      allowedRoles:
        - os:admin
    {% endif %}
    rbac: true
  nodeLabels:
    node.kubernetes.io/exclude-from-external-load-balancers: ""
    topology.kubernetes.io/region: main
  files:
    - op: create
      path: /etc/cri/conf.d/20-customization.part
      content: |
        [plugins."io.containerd.cri.v1.images"]
          discard_unpacked_layers = false
        [plugins."io.containerd.cri.v1.runtime"]
          cdi_spec_dirs = ["/var/cdi/static", "/var/cdi/dynamic"]
          device_ownership_from_security_context = true
    - op: overwrite
      path: /etc/nfsmount.conf
      permissions: 0o644
      content: |
        [ NFSMount_Global_Options ]
        nfsvers=4.2
        hard=True
        nconnect=8
        noatime=True
        rsize=1048576
        wsize=1048576
  sysctls:
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "1048576"
    net.core.default_qdisc: fq
    net.core.rmem_max: "67108864"
    net.core.wmem_max: "67108864"
    net.ipv4.neigh.default.gc_thresh1: "4096"
    net.ipv4.neigh.default.gc_thresh2: "8192"
    net.ipv4.neigh.default.gc_thresh3: "16384"
    net.ipv4.ping_group_range: 0 2147483647
    net.ipv4.tcp_congestion_control: bbr
    net.ipv4.tcp_fastopen: "3"
    net.ipv4.tcp_mtu_probing: "1"
    net.ipv4.tcp_notsent_lowat: "131072"
    net.ipv4.tcp_rmem: 4096 87380 33554432
    net.ipv4.tcp_slow_start_after_idle: "0"
    net.ipv4.tcp_window_scaling: "1"
    net.ipv4.tcp_wmem: 4096 65536 33554432
    sunrpc.tcp_max_slot_table_entries: "128"
    sunrpc.tcp_slot_table_entries: "128"
    user.max_user_namespaces: "11255"
    vm.nr_hugepages: "1024"
  time:
    disabled: false
    servers:
      - 10.4.1.1
cluster:
  id: {{ ENV.CLUSTER_ID }}
  secret: {{ ENV.CLUSTER_SECRET }}
  controlPlane:
    endpoint: https://10.4.3.1:6443
  clusterName: servonet
  network:
    cni:
      name: none
    dnsDomain: servonet.lan
    podSubnets:
      - 10.244.0.0/16
    serviceSubnets:
      - 10.96.0.0/12
  token: 7xbdc5.4gj2i9fhgwzhxvwl
  secretboxEncryptionSecret: {{ ENV.CLUSTER_SECRETBOX_ENCRYPTION_SECRET }}
  ca:
    crt: {{ ENV.CLUSTER_CA_CRT }}
    {% if ENV.IS_CONTROLLER %}
    key: {{ ENV.CLUSTER_CA_KEY }}
    {% endif %}
  {% if ENV.IS_CONTROLLER %}
  aggregatorCA:
    crt: {{ ENV.CLUSTER_AGGREGATOR_CA_CRT }}
    key: {{ ENV.CLUSTER_AGGREGATOR_CA_KEY }}
  serviceAccount:
    key: {{ ENV.CLUSTER_SERVICE_ACCOUNT_KEY }}
  apiServer:
    image: registry.k8s.io/kube-apiserver:v1.35.2
    certSANs:
      - cluster.local
      - servonet.lan
      - 127.0.0.1
    extraArgs:
      enable-aggregator-routing: "true"
      feature-gates: MutatingAdmissionPolicy=true
      runtime-config: admissionregistration.k8s.io/v1beta1=true
    admissionControl:
      - name: PodSecurity
        configuration:
          apiVersion: pod-security.admission.config.k8s.io/v1alpha1
          defaults:
            audit: restricted
            audit-version: latest
            enforce: baseline
            enforce-version: latest
            warn: restricted
            warn-version: latest
          exemptions:
            namespaces:
              - kube-system
            runtimeClasses: []
            usernames: []
          kind: PodSecurityConfiguration
    auditPolicy:
      apiVersion: audit.k8s.io/v1
      kind: Policy
      rules:
        - level: Metadata
  controllerManager:
    image: registry.k8s.io/kube-controller-manager:v1.35.2
  proxy:
    image: registry.k8s.io/kube-proxy:v1.35.2
  scheduler:
    image: registry.k8s.io/kube-scheduler:v1.35.2
  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: true
      service: {}
  etcd:
    ca:
      crt: {{ ENV.CLUSTER_ETCD_CA_CRT }}
      key: {{ ENV.CLUSTER_ETCD_CA_KEY }}
  allowSchedulingOnControlPlanes: true
  {% endif %}
---
apiVersion: v1alpha1
kind: ResolverConfig
nameservers:
  - address: 10.4.1.1
searchDomains:
  disableDefault: false
---
apiVersion: v1alpha1
kind: DHCPv4Config
name: ethSel0
clientIdentifier: mac
---
apiVersion: v1alpha1
kind: Layer2VIPConfig
name: 10.4.3.1
link: ethSel0
---
apiVersion: v1alpha1
kind: LinkConfig
name: ethSel0
mtu: 1500
---
apiVersion: v1alpha1
kind: TrustedRootsConfig
name: step-ca # Name of the config document.
certificates: |
  {{ ENV.STEP_CA_ROOT | indent(2, false) }}
